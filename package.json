{
  "name": "@finsys/lender-client",
  "version": "2.0.0",
  "description": "Typed API client for the FinSys Lender API with built-in environment management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "axios-retry": "^4.5.0",
    "form-data": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "typescript": "~5.4"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ExtraGalaxies/finsys-lender-client"
  }
}
